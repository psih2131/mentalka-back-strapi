{
  "kind": "collectionType",
  "collectionName": "reviews",
  "info": {
    "singularName": "review",
    "pluralName": "reviews",
    "displayName": "reviews"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "reviews_category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::reviews-category.reviews-category",
      "inversedBy": "reviews"
    },
    "autor_name": {
      "type": "string",
      "required": true
    },
    "review_text": {
      "type": "text",
      "required": true
    },
    "date": {
      "type": "date"
    },
    "autor_photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "rate": {
      "type": "decimal",
      "required": true,
      "default": 5,
      "max": 5
    }
  }
}
