{
  "kind": "collectionType",
  "collectionName": "reviews_categories",
  "info": {
    "singularName": "reviews-category",
    "pluralName": "reviews-categories",
    "displayName": "reviews-categories"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "category_name": {
      "type": "string"
    },
    "category_logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "category_link": {
      "type": "string"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "reviews_category"
    }
  }
}
