{
  "collectionName": "components_shared_seos",
  "info": {
    "name": "Seo",
    "icon": "allergies",
    "displayName": "Seo",
    "description": "SEO-поля страницы: мета-теги, Open Graph, Twitter Cards, canonical, robots, JSON-LD"
  },
  "options": {},
  "attributes": {
    "metaTitle": {
      "type": "string",
      "required": true,
      "maxLength": 70
    },
    "metaDescription": {
      "type": "text",
      "required": true,
      "maxLength": 160
    },
    "metaKeywords": {
      "type": "text"
    },
    "focusKeyword": {
      "type": "string"
    },
    "canonicalURL": {
      "type": "string"
    },
    "metaRobots": {
      "type": "enumeration",
      "enum": [
        "index, follow",
        "noindex, follow",
        "index, nofollow",
        "noindex, nofollow"
      ],
      "default": "index, follow"
    },
    "shareImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "ogTitle": {
      "type": "string",
      "maxLength": 70
    },
    "ogDescription": {
      "type": "text",
      "maxLength": 200
    },
    "ogType": {
      "type": "enumeration",
      "enum": ["website", "article", "product", "profile"],
      "default": "website"
    },
    "ogLocale": {
      "type": "string",
      "default": "ru_RU"
    },
    "twitterCard": {
      "type": "enumeration",
      "enum": ["summary", "summary_large_image", "app", "player"],
      "default": "summary_large_image"
    },
    "twitterTitle": {
      "type": "string",
      "maxLength": 70
    },
    "twitterDescription": {
      "type": "text",
      "maxLength": 200
    },
    "twitterImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "twitterSite": {
      "type": "string"
    },
    "twitterCreator": {
      "type": "string"
    },
    "structuredData": {
      "type": "json"
    }
  }
}
